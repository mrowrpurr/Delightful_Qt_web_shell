{
  "name": "delightful-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:main": "cd apps/main && vite",
    "dev:docs": "cd apps/docs && vite",
    "build:main": "cd apps/main && tsc -b && vite build",
    "build:docs": "cd apps/docs && tsc -b && vite build",
    "build": "npm run build:main && npm run build:docs",
    "typecheck": "cd apps/main && tsc -b --noEmit && cd ../docs && tsc -b --noEmit"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.5.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
